(function(){
  var tracks = document.querySelectorAll('.category-carousel-track');
  tracks.forEach(function(track){
    var wrap = track.closest('.category-carousel-wrap');
    if (!wrap) return;
    var prev = wrap.querySelector('.cat-prev');
    var next = wrap.querySelector('.cat-next');

    function getScrollAmount() {
      var card = track.querySelector('.product-card');
      if (!card) return 300;
      return card.offsetWidth + 16;
