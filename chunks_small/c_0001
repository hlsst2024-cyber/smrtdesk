  var prev = document.getElementById('heroPrev');
  var next = document.getElementById('heroNext');
  var current = 0;
  function goTo(index){
    slides.forEach(function(s,i){ s.classList.toggle('active', i===index); });
    current = index;
  }
  if(prev && next && slides.length > 0){
    prev.addEventListener('click', function(){ goTo((current - 1 + slides.length) % slides.length); });
    next.addEventListener('click', function(){ goTo((current + 1) % slides.length); });
    setInterval(function(){ goTo((current + 1) % slides.length); }, 5000);
  }
})();
</script>

